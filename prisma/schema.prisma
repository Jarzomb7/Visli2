generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("client")
  name      String?
  language  String   @default("pl")
  stripeCustomerId String? @unique @map("stripe_customer_id")
  createdAt DateTime @default(now()) @map("created_at")
  addons    Addon[]
  licenses  License[]
  subscriptions Subscription[]

  @@index([role])
  @@map("users")
}

model License {
  id           Int        @id @default(autoincrement())
  key          String     @unique
  domain       String
  status       String     @default("active")
  plan         String     @default("basic")
  features     String[]   @default([])
  email        String?
  userId       Int?       @map("user_id")
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  domainLocked Boolean    @default(false) @map("domain_locked")
  stripeSubId  String?    @map("stripe_sub_id")
  expiresAt    DateTime   @map("expires_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  productId    Int?       @map("product_id")
  product      Product?       @relation(fields: [productId], references: [id])
  usageLogs    UsageLog[]
  subscription Subscription?

  @@index([email])
  @@index([userId])
  @@index([stripeSubId])
  @@map("licenses")
}

model Product {
  id            Int            @id @default(autoincrement())
  name          String
  code          String         @unique
  description   String?
  stripePriceId String?        @map("stripe_price_id")
  paymentType   String         @default("subscription") @map("payment_type")
  priceCents    Int?           @map("price_cents")
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now()) @map("created_at")
  licenses      License[]
  subscriptions Subscription[]

  @@map("products")
}

model ValidationLog {
  id        Int      @id @default(autoincrement())
  licenseKey String  @map("license_key")
  domain    String
  product   String?
  result    String
  reason    String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("validation_logs")
}

model Subscription {
  id                   Int       @id @default(autoincrement())
  email                String
  userId               Int?      @map("user_id")
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  status               String    @default("incomplete")
  plan                 String    @default("basic")
  productCode          String?   @map("product_code")
  productId            Int?      @map("product_id")
  product              Product?  @relation(fields: [productId], references: [id])
  licenseId            Int?      @unique @map("license_id")
  license              License?  @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAt             DateTime? @map("cancel_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model UsageLog {
  id        Int      @id @default(autoincrement())
  licenseId Int      @map("license_id")
  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  event     String
  meta      String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([licenseId])
  @@map("usage_logs")
}

model Feature {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  name         String
  description  String?
  category     String?
  createdAt    DateTime      @default(now()) @map("created_at")
  planFeatures PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id        Int     @id @default(autoincrement())
  plan      String
  product   String?
  featureId Int     @map("feature_id")
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([plan, featureId, product])
  @@index([plan])
  @@map("plan_features")
}

model Addon {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  amount    Int      @default(0)
  status    String   @default("active")
  meta      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("addons")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  group     String   @default("general")
  label     String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("settings")
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  subject   String
  body      String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_resets")
}
